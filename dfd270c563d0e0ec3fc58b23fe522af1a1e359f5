            "content": "import { Effect, Schema } from \"effect\";\nimport { describe, expect, it } from \"vitest\";\n\nimport {\n  Base64IdSchema,\n  EmailSchema,\n  JerseyNumberSchema,\n  NanoidSchema,\n  PlayerNameSchema,\n  SerialSchema,\n} from \"./schema\";\n\nconst decode = <A, I>(schema: Schema.Schema<A, I>, input: I) =>\n  Effect.runPromise(Schema.decode(schema)(input));\n\nconst decodeFail = <A, I>(schema: Schema.Schema<A, I>, input: I) =>\n  expect(Effect.runPromise(Schema.decode(schema)(input))).rejects.toThrow();\n\ndescribe(\"NanoidSchema\", () => {\n  it(\"accepts valid 12-char nanoid\", async () => {\n    const result = await decode(NanoidSchema, \"AbCdEfGhIjKl\");\n    expect(result).toBe(\"AbCdEfGhIjKl\");\n  });\n\n  it(\"accepts nanoid with underscores and hyphens\", async () => {\n    const result = await decode(NanoidSchema, \"Ab_d-fGhIjKl\");\n    expect(result).toBe(\"Ab_d-fGhIjKl\");\n  });\n\n  it(\"rejects wrong length\", () => decodeFail(NanoidSchema, \"short\"));\n  it(\"rejects too long\", () => decodeFail(NanoidSchema, \"AbCdEfGhIjKlX\"));\n  it(\"rejects invalid chars\", () => decodeFail(NanoidSchema, \"AbCdEf!hIjKl\"));\n});\n\ndescribe(\"SerialSchema\", () => {\n  it(\"accepts 0\", async () => {\n    expect(await decode(SerialSchema, 0)).toBe(0);\n  });\n  it(\"accepts positive int\", async () => {\n    expect(await decode(SerialSchema, 42)).toBe(42);\n  });\n  it(\"rejects negative\", () => decodeFail(SerialSchema, -1));\n  it(\"rejects float\", () => decodeFail(SerialSchema, 1.5));\n});\n\ndescribe(\"EmailSchema\", () => {\n  it(\"accepts valid email\", async () => {\n    expect(await decode(EmailSchema, \"test@example.com\")).toBe(\n      \"test@example.com\",\n    );\n  });\n  it(\"rejects missing @\", () => decodeFail(EmailSchema, \"notanemail\"));\n  it(\"rejects missing domain\", () => decodeFail(EmailSchema, \"test@\"));\n});\n\ndescribe(\"PlayerNameSchema\", () => {\n  it(\"accepts valid name\", async () => {\n    expect(await decode(PlayerNameSchema, \"John\")).toBe(\"John\");\n  });\n  it(\"rejects empty string\", () => decodeFail(PlayerNameSchema, \"\"));\n  it(\"rejects >100 chars\", () =>\n    decodeFail(PlayerNameSchema, \"A\".repeat(101)));\n});\n\ndescribe(\"JerseyNumberSchema\", () => {\n  it(\"accepts 0\", async () => {\n    expect(await decode(JerseyNumberSchema, 0)).toBe(0);\n  });\n  it(\"accepts 999\", async () => {\n    expect(await decode(JerseyNumberSchema, 999)).toBe(999);\n  });\n  it(\"accepts 1000\", async () => {\n    expect(await decode(JerseyNumberSchema, 1000)).toBe(1000);\n  });\n  it(\"rejects negative\", () => decodeFail(JerseyNumberSchema, -1));\n  it(\"rejects >1000\", () => decodeFail(JerseyNumberSchema, 1001));\n  it(\"rejects float\", () => decodeFail(JerseyNumberSchema, 1.5));\n});\n\ndescribe(\"Base64IdSchema\", () => {\n  it(\"accepts valid 32-char alphanumeric\", async () => {\n    const id = \"a\".repeat(32);\n    expect(await decode(Base64IdSchema(), id)).toBe(id);\n  });\n  it(\"rejects wrong length\", () => decodeFail(Base64IdSchema(), \"short\"));\n  it(\"rejects special chars\", () =>\n    decodeFail(Base64IdSchema(), \"a\".repeat(31) + \"!\"));\n});\n",
