{
  "name": "@laxdb/pipeline",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "bun --bun vitest",
    "test:coverage": "bun --bun vitest run --coverage",
    "test:pll": "bun --bun vitest run src/pll/",
    "test:nll": "bun --bun vitest run src/nll/",
    "test:mll": "bun --bun vitest run src/mll/",
    "test:msl": "bun --bun vitest run src/msl/",
    "test:wla": "bun --bun vitest run src/wla/",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.43",
    "@laxdb/core": "*",
    "cheerio": "^1.1.2",
    "effect": "^4.0.0-beta.43"
  },
  "devDependencies": {},
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
