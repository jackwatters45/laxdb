{
  "name": "@laxdb/pipeline",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "bunx --bun vitest",
    "test:coverage": "bunx --bun vitest run --coverage",
    "test:pll": "bunx --bun vitest run src/pll/",
    "test:nll": "bunx --bun vitest run src/nll/",
    "test:mll": "bunx --bun vitest run src/mll/",
    "test:msl": "bunx --bun vitest run src/msl/",
    "test:wla": "bunx --bun vitest run src/wla/", 
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "fix": "bun run lint && bun run format"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.31",
    "@laxdb/core": "*",
    "cheerio": "^1.1.2",
    "effect": "^4.0.0-beta.31"
  },
  "devDependencies": {},
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
