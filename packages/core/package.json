{
  "name": "@laxdb/core",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "db": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "better-auth:gen": "npx @better-auth/cli@latest generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.972.0",
    "@effect/vitest": "^4.0.0-beta.43",
    "@polar-sh/better-auth": "^1.6.4",
    "@polar-sh/sdk": "^0.42.2",
    "better-auth": "^1.4.17",
    "drizzle-orm": "^1.0.0-beta.9-e89174b",
    "effect": "^4.0.0-beta.43",
    "nanoid": "^5.1.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@effect/build-utils": "^0.8.9",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "fetchdts": "^0.1.7",
    "tsx": "^4.21.0"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
