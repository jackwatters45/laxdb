{
  "name": "@laxdb/fines",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3005",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "db": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@laxdb/core": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.143.11",
    "@tanstack/react-start": "^1.143.12",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^1.0.0-beta.9-e89174b",
    "effect": "4.0.0-beta.66",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
