{
  "name": "@laxdb/rules-wiki",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3005",
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
