{
  "extends": "../../tsconfig.json",
  "include": ["**/*.ts", "**/*.tsx", "types/**/*.d.ts", "../../types/**/*.d.ts"],
  "exclude": ["node_modules", ".output"],
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
