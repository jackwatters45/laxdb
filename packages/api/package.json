{
  "name": "@laxdb/api",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@laxdb/core": "workspace:*",
    "effect": "^4.0.0-beta.43"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "pg": "^8.16.0",
    "vitest": "^3.2.1"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
