{
  "name": "@laxdb/cli",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.43",
    "@laxdb/api": "workspace:*",
    "@laxdb/core": "workspace:*",
    "effect": "^4.0.0-beta.43"
  },
  "devDependencies": {
    "pg": "^8.16.0",
    "vitest": "^3.2.1"
  }
}
