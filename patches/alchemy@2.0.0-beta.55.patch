 import * as Effect from "effect/Effect";
 import * as Redacted from "effect/Redacted";
 import { createRequire } from "node:module";
+import * as NodeNet from "node:net";
 import path from "node:path";
 import { pathToFileURL } from "node:url";
 import type * as vite from "vite";
+
+const reservedVitePorts = new Set<number>();
+const viteServerPorts = new WeakMap<vite.ViteDevServer, number>();
+
+const reserveAvailableVitePort = async (): Promise<number> => {
+  while (true) {
+    const port = await new Promise<number>((resolve, reject) => {
+      const server = NodeNet.createServer();
+      server.once("error", reject);
+      server.listen(
+        { host: "127.0.0.1", port: 0, exclusive: true },
+        () => {
+          const address = server.address();
+          if (!address || typeof address === "string") {
+            server.close(() =>
+              reject(new Error("Failed to allocate a Vite development port")),
+            );
+            return;
+          }
+          server.close((error) =>
+            error ? reject(error) : resolve(address.port),
+          );
+        },
+      );
+      server.unref();
+    });
+    if (!reservedVitePorts.has(port)) {
+      reservedVitePorts.add(port);
+      return port;
+    }
+  }
+};
 
